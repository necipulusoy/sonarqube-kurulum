# Fonksiyonel EC2 testinde Docker Hub; Nexus testinde Nexus image adresini kullanın.
SONARQUBE_IMAGE=sonarqube:<ONAYLI_SURUM>-enterprise

# EC2 test container self-signed sertifika kullandığı için true. Production'da false olmalıdır.
SONAR_JDBC_URL=jdbc:sqlserver://<MSSQL_PRIVATE_IP>:1433;databaseName=sonarqube_test;encrypt=true;trustServerCertificate=true
SONAR_JDBC_USERNAME=sonarqube_test
SONAR_JDBC_PASSWORD='<DEGISTIRIN>'

SONAR_BIND_ADDRESS=0.0.0.0
SONAR_HOST_PORT=9000
SONAR_WEB_HOST=0.0.0.0
SONAR_WEB_PORT=9000
SONAR_WEB_CONTEXT=/
