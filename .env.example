# Nexus'taki tam ve immutable image adresi. Mümkünse tag yerine digest kullanın.
SONARQUBE_IMAGE=nexus.example.local:5000/docker-hosted/sonarqube:2026.3-enterprise

# External MSSQL. Production'da encrypt=false kullanmayın.
SONAR_JDBC_URL=jdbc:sqlserver://mssql.example.local:1433;databaseName=sonarqube;encrypt=true;trustServerCertificate=false;hostNameInCertificate=mssql.example.local
SONAR_JDBC_USERNAME=sonarqube
SONAR_JDBC_PASSWORD='DEGISTIRIN'

# Reverse proxy yoksa 0.0.0.0; yalnızca lokal proxy erişecekse 127.0.0.1.
SONAR_BIND_ADDRESS=0.0.0.0
SONAR_HOST_PORT=9000
SONAR_WEB_HOST=0.0.0.0
SONAR_WEB_PORT=9000
SONAR_WEB_CONTEXT=/
